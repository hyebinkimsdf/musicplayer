{
  "name": "music-player",
  "version": "0.1.0",
  "private": true,
  "homepage": "./",
  "main": "electron.js",
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-scripts": "5.0.1",
    "tone": "^15.1.22",
    "web-vitals": "^2.1.4",
    "yt-dlp-wrap": "^2.3.12"
  },
  "scripts": {
    "start": "react-scripts start",
    "electron": ".\\node_modules\\electron\\dist\\electron.exe .",
    "dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && npm run electron\"",
    "build": "react-scripts build",
    "dist": "npm run build && electron-builder",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "build": {
    "extends": null,
    "appId": "com.musicplayer.app",
    "productName": "Music Player",
    "files": [
      "build/**/*",
      "electron.js",
      "preload.js",
      "package.json",
      "public/icon.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.5.2",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.10"
  }
}
